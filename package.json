{
  "name": "sveltekit-blog-starter",
  "version": "2.0.2",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "lint": "eslint --ignore-path .gitignore .",
    "format": "eslint --ignore-path .gitignore --fix .",
    "prepare": "vp config"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "motion": "^12.38.0",
    "motion-sv": "^0.1.12",
    "svelte-meta-tags": "^4.6.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.12.0",
    "@sveltejs/adapter-static": "latest",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "latest",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.19.17",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "mdsvex": "^0.12.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "shadcn-svelte": "^1.2.7",
    "shiki": "^4.0.2",
    "svelte": "^5.55.5",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.19",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "fmt": {
    "useTabs": true,
    "singleQuote": true,
    "trailingComma": "none",
    "printWidth": 100,
    "sortTailwindcss": {
      "stylesheet": "./src/routes/layout.css"
    },
    "sortPackageJson": false
  },
  "staged": {
    "hooks": {
      "*.{js,ts,svelte}": [
        "fmt",
        "lint",
        "test"
      ]
    }
  }
}
